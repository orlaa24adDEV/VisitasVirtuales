{
	"name": "visitasvirtualeszaitec",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"dev": "npm run openapi:generate && tsx watch src/index.ts",
		"db:up": "docker compose up -d postgres_service",
		"db:down": "docker compose down postgres_service",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx --import ./src/env.ts src/db/seed.ts",
		"db:logs": "docker compose logs -f postgres_service",
		"storage:up": "docker compose up -d minio_service",
		"storage:down": "docker compose down minio_service",
		"sorage:logs": "docker compose logs -f minio_service",
		"prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build",
		"prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.prod down",
		"prod:restart": "npm run prod:down && npm run prod:up",
		"stage:db:seed": "node --import ./dist/env.js dist/db/seed.js",
		"prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.prod logs -f api_service",
		"prod:ps": "docker compose -f docker-compose.prod.yml --env-file .env.prod ps",
		"stage:up": "docker compose -f docker-compose.stage.yml --env-file .env.stage up -d --build",
		"stage:down": "docker compose -f docker-compose.stage.yml --env-file .env.stage down",
		"stage:restart": "npm run stage:down && npm run stage:up",
		"stage:logs": "docker compose -f docker-compose.stage.yml --env-file .env.stage logs -f api_service",
		"stage:ps": "docker compose -f docker-compose.stage.yml --env-file .env.stage ps",
		"build": "tsc",
		"openapi:generate": "node scripts/generate-openapi.js",
		"format": "prettier --write ."
	},
	"repository": {
		"type": "git",
		"url": "git@github.com:jaimemoya-bit/VisitasVirtualesZaitec.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"bcrypt": "^6.0.0",
		"cookie-parser": "^1.4.7",
		"cookieparser": "^0.1.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.1",
		"dotenv-expand": "^12.0.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"express": "^5.2.1",
		"express-rate-limit": "^8.4.1",
		"helmet": "^8.1.0",
		"jose": "^6.2.2",
		"jsonwebtoken": "^9.0.3",
		"latest": "^0.2.0",
		"minio": "^8.0.7",
		"morgan": "^1.10.1",
		"multer": "^2.1.1",
		"pg": "^8.20.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"yamljs": "^0.3.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@hey-api/openapi-ts": "^0.94.5",
		"@types/bcrypt": "^6.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/swagger-ui-express": "^4.1.8",
		"dotenv-cli": "^11.0.0",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0"
	}
}
