{
	"name": "visitasvirtualeszaitec",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"dev": "APP_STAGE=dev nodemon --watch 'src/**/*.{js,ts}' --exec 'node --import ./env.ts src/app.js'",
		"db:up": "docker compose up -d",
		"db:up:watch": "docker compose up",
		"db:down": "docker compose down",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:prod": "drizzle-kit migrate --env production",
		"db:studio": "drizzle-kit studio",
		"db:seed": "APP_STAGE=dev node --import ./env.ts src/db/seed.js",
		"db:logs": "docker compose logs -f postgres_service",
		"deploy:prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build",
		"deploy:prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.prod down",
		"deploy:prod:restart": "npm run deploy:prod:down && npm run deploy:prod:up",
		"deploy:prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.prod logs -f api_service nginx_service",
		"deploy:prod:ps": "docker compose -f docker-compose.prod.yml --env-file .env.prod ps",
		"openapi:generate": "node scripts/generate-openapi.js",
		"format": "prettier --write ."
	},
	"repository": {
		"type": "git",
		"url": "git@github.com:jaimemoya-bit/VisitasVirtualesZaitec.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"bcrypt": "^6.0.0",
		"cookie-parser": "^1.4.7",
		"cookieparser": "^0.1.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.1",
		"dotenv-expand": "^12.0.3",
		"drizzle-orm": "^0.45.1",
		"express": "^5.2.1",
		"jose": "^6.2.2",
		"jsonwebtoken": "^9.0.3",
		"morgan": "^1.10.1",
		"pg": "^8.20.0",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"yamljs": "^0.3.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@hey-api/openapi-ts": "^0.94.5",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.1"
	}
}
